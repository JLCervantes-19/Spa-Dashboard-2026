# Serenità Admin Dashboard — Variables de entorno
# Copiar este archivo como .env y completar los valores

# ─── SUPABASE ────────────────────────────────────────────────────────────────
# URL del proyecto Supabase (visible en Project Settings → API)
SUPABASE_URL=https://tu-proyecto.supabase.co

# Anon/public key — va en el frontend, es pública
# NO usar service_role key en el frontend
SUPABASE_ANON_KEY=eyJhbGc...

# ─── SOLO PARA SCRIPTS / FUNCIONES SERVERLESS ────────────────────────────────
# Service role key — NUNCA exponer en el frontend, NUNCA commitear
# Usado solo si se agregan funciones serverless de administración avanzada
# SUPABASE_SERVICE_KEY=eyJhbGc...
